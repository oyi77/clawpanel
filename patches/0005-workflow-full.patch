+  btn.disabled = true
+  try {
+    await api.workflowRunResume(_selectedRun.id)
+    toast('Workflow resumed', 'success')
+    page.querySelector('#run-modal').style.display = 'none'
+    loadRuns(page)
+  } catch (e) {
+    toast(e.message, 'error')
