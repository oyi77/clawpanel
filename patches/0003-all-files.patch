+
+  workflow_run_resume({ id }) {
+    return { id, status: 'running', meta: 'Resumed' }
+  },
+
+  workflow_run_get({ id }) {
+    const all = this.workflow_run_list({})
+    const r = all.find(r => r.id === id)
+    if (!r) throw new Error('Run not found')
+    return r
+  },
+
